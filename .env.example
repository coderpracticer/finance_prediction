# Backend runtime config
FRA_CONFIG_PATH=configs/data_source_spike.json
FRA_DATABASE_PATH=data/app.db
FRA_RAW_DIR=data/raw/mvp

# Comma-separated browser origins allowed by FastAPI CORS.
# For a remote server, replace <server-ip> with the server address users open in the browser.
FRA_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://<server-ip>:8000

# SEC recommends a descriptive User-Agent with contact information.
SEC_USER_AGENT=FinancialResearchAgent/0.1 your-email@example.com

# Optional price fallback when Yahoo/Stooq are blocked by server IP.
ALPHA_VANTAGE_API_KEY=

# Local OpenAI-compatible LLM API running on the 2x4090 server.
LOCAL_LLM_BASE_URL=http://127.0.0.1:8001/v1
LOCAL_LLM_API_KEY=local
LOCAL_LLM_MODEL=your-local-model-name
LOCAL_LLM_TIMEOUT_SECONDS=60
